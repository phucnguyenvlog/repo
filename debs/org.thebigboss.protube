<div class="comment-title">
    <span  class="rate">
        当前版本 : <a>未评分&nbsp; &nbsp;</a>

    </span>
</div>
<div id="cur-loading-gif" class="col-xs-12 hide" style="padding: 100px 0">
    <img src="/images/ico_loading.gif" class="col-xs-offset-5" />

</div>

        <p class="infomation">暂无评论.</p>




    <script type="text/javascript">
        var currentPage=1;
        $("#curCommentPager .index :not(:last)").addClass("disable").first().removeClass("disable");
        $(function () {
            $(".comment-item:last").css("border-bottom","0px")
            if(currentPage==(0))
            {
                $("#curCommentPager .right_pointer").css("background-color","#808080").css("cursor","default");
            }
            if(currentPage==1)
            {
                $("#curCommentPager .left_pointer").css("background-color","#808080").css("cursor","default");
            }

            $("#curCommentPager .right_pointer").bind("click",function(){
                if(currentPage==(0))
                {//alert("已经是最后一页...");
                }
                else{
                    $("#curHide-part").fadeOut(function(){
                        $("#cur-loading-gif").removeClass("hide");
                        commentAjax(currentPage+1,"#curComments",1,'org.thebigboss.protube',"#curHide-part",1);
                    })
                  
                }
            })
            $("#curCommentPager .left_pointer").bind("click",function(){
                if(currentPage==1)
                {//alert("已经是第一页...");
                }
                else{
                    $("#curHide-part").fadeOut(function(){
                        $("#cur-loading-gif").removeClass("hide");
                        commentAjax(currentPage-1,"#curComments",1,'org.thebigboss.protube',"#curHide-part",1);
                    })
                }
            })
            //每次加载将当前页面的颜色变成激活状态
            $("#curCommentPager .index").each(function () {
                if($(this).attr("tag")==currentPage)
                {
                    $(this).addClass("active")
                }
            })
            if(currentPage<=3)
            {
                for(var i=1;i<4;i++)
                {
                    $($("#curCommentPager .index")[i]).removeClass("disable");
                }
            }
            if(currentPage>3)
            {
                for(var i=3;i>0;i--)
                {
                    $($("#curCommentPager .index")[currentPage-i+1]).removeClass("disable");
                }
            }
            if(currentPage>0-2)
            {
                for(var i=4;i>0;i--)
                {
                    $($("#curCommentPager .index")[0-i]).removeClass("disable");
                }
            }
            $("#curCommentPager .index").click(function () {
                var tag=$(this).attr("tag")
                $("#curHide-part").fadeOut(function(){
                    $("#cur-loading-gif").removeClass("hide");
                    commentAjax(tag,"#curComments",1,'org.thebigboss.protube',"#curHide-part",1);
                })
                })
            //curHide-part
            //给每一个评论者的星级进行绘画

            $(".rate-star").each(function(){
                var  pointer=$(this).attr("tag");
                //用天花板函数来决定star
                var double_star=Math.ceil(pointer-1)/2;
                var only_star=Math.ceil(pointer)%2;

                for(var i=0;i<double_star;i++)
                {
                    $($(this).children("span")[i]).addClass("icon-star-two").removeClass("icon-star-zero");
                }
                for(var j=double_star;j<double_star+only_star;j++)
                {
                    $($(this).children("span")[i]).addClass("icon-star-one").removeClass("icon-star-zero");
                }

            })

        })
      
    </script>


