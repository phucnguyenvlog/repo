        </div>

    </div>

    <script type="text/javascript">
        function GotodebList(sectionID) { window.location = '/DebList/' + sectionID; }
        function GotoAuthorInfo(authorID) { window.location = '/AuthorInfo/' + authorID }


        //向插件详细页面跳转的方法
        function pageJump(Package) {
            window.location = "/DebDetailPC/" + Package;
        }
        $(function () {

            $(".icon-white-circle-right-pointer").mouseenter(function () {
                $(this).toggleClass("icon-blue-circle-right-pointer").toggleClass("icon-white-circle-right-pointer")
            }).mouseleave(function () {
                $(this).toggleClass("icon-blue-circle-right-pointer").toggleClass("icon-white-circle-right-pointer")
            })

            $(".header ul li:eq(" + 2 + ")").addClass("active");



    })
    </script>
