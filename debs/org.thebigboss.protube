<p  class="comment-title">
    <span class="rate">
        历史版本 : <a>未评分&nbsp; &nbsp;</a>
    </span>
</p>
<div id="his-loading-gif" class="col-xs-12 hide" style="padding: 100px 0">
    <img src="/images/ico_loading.gif" class="col-xs-offset-5" />

</div>
        <p class="infomation">暂无评论. </p> 

 

    <script type="text/javascript">
    var hisCurrentPage=1;
    $("#hisCommentPager .index :not(:last)").addClass("disable").first().removeClass("disable");
    $(function () {
        if(hisCurrentPage==(0))
        {
            $("#hisCommentPager .right_pointer").css("background-color","#808080").css("cursor","default");
        }
        if(hisCurrentPage==1)
        {
            $("#hisCommentPager .left_pointer").css("background-color","#808080").css("cursor","default");
        }

        $("#hisCommentPager .right_pointer").bind("click",function(){
            if(hisCurrentPage==(0))
            {//alert("已经是最后一页...");
            }
            else{
                $("#hisHide-part").fadeOut(function(){
                    $("#his-loading-gif").removeClass("hide");
                    commentAjax(hisCurrentPage+1,"#hisComments",2,'org.thebigboss.protube',"#hisHide-part",0);
                })

            }
        })
        $("#hisCommentPager .left_pointer").bind("click",function(){
            if(hisCurrentPage==1)
            {//alert("已经是第一页...");
            }
            else{
                $("#hisHide-part").fadeOut(function(){
                    $("#his-loading-gif").removeClass("hide");
                    commentAjax(hisCurrentPage-1,"#hisComments",2,'org.thebigboss.protube',"#hisHide-part",0);
                })

            }
        })
        //每次加载将当前页面的颜色变成激活状态
        $("#hisCommentPager .index").each(function () {
            if($(this).attr("tag")==hisCurrentPage)
            {
                $(this).addClass("active")
            }
        })
        if(hisCurrentPage<=3)
        {

            for(var i=1;i<4;i++)
            {
                $($("#hisCommentPager .index")[i]).removeClass("disable");
            }
        }
        if(hisCurrentPage>3)
        {
            for(var i=3;i>0;i--)
            {
                $($("#hisCommentPager .index")[hisCurrentPage-i+1]).removeClass("disable");
            }
        }
        if(hisCurrentPage>0-2)
        {
            for(var i=4;i>0;i--)
            {
                $($("#hisCommentPager .index")[0-i]).removeClass("disable");
            }
        }
        $("#hisCommentPager .index").click(function () {
            var tag=$(this).attr("tag")
            $("#hisHide-part").fadeOut(function(){
                $("#his-loading-gif").removeClass("hide");
                commentAjax(tag,"#hisComments",2,'org.thebigboss.protube',"#hisHide-part",0);
            })
           
        })
        //给每一个评论者的星级进行绘画

        $(".rate-star").each(function(){
            var  pointer=$(this).attr("tag");
            //用天花板函数来决定star
            var double_star=Math.ceil(pointer-1)/2;
            var only_star=Math.ceil(pointer)%2;

            for(var i=0;i<double_star;i++)
            {
                $($(this).children("span")[i]).addClass("icon-star-two").removeClass("icon-star-zero");
            }
            for(var j=double_star;j<double_star+only_star;j++)
            {
                $($(this).children("span")[i]).addClass("icon-star-one").removeClass("icon-star-zero");
            }

        })
    })

</script>


                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>



<div class="right-slider width0 col-lg-5 col-md-7  col-sm-8 col-md-7 col-xs-9">
    <div id="right_button">
        <div class="top">
            <a class="icon-submit-bug" style="vertical-align: middle;"></a>
        </div>
        <p>
            本页面有误<br />
            ?
        </p>
    </div>
    <div class="err-title">
        本插件页信息有误?点击反馈
    </div>
    <p>由于国外插件咨询量，较大，我们已经尽可能的保证插件详细页内容的准确，和可靠性。建立一个准确可读的数据内容 ，离不开大家的共同努力。如果发现本页面下列地方内容有误，勾选错误内容的类别。如果可以，请同时备注错误的地方。</p>
    <div class="selectPannel row">
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="0" id="0" /><label for="0">简介有误</label>
            </span>
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="1" id="1" /><label for="1">使用说明(详细介绍)有误</label>
            </span>
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="2" id="2" /><label for="2">支持设备类型有误</label>
            </span>
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="3" id="3" /><label for="3">版本未及时更新</label>
            </span>
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="4" id="4" /><label for="4">截图有误</label>
            </span>
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="5" id="5" /><label for="5">更新日志内容有误</label>
            </span>
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="6" id="6" /><label for="6">含有恶意代码</label>
            </span>
            <span class="col-xs-12  col-sm-6  col-lg-6 col-md-6">
                <input type="radio" name="errorType" value="7" id="7" /><label for="7">功能异常</label>
            </span>



    </div>
    <p class="title"><span class="icon-blue-chain" style="vertical-align: middle;"></span>&nbsp; &nbsp; 备注 :</p>
    <textarea placeholder="请简单告诉我们错误的具体位置" id="err-msg"></textarea>
    <div class="btn-submit btn" id="err-submit">提交</div>
</div>


<script language="javascript" type="text/javascript">

    var g_resize_count = 0;
    $(document).ready(function () {

        try {
            $window = $(window);
            var resize = $window.jqElemResize();
            //resize.$self.on("resize", function (size)或
            $(resize).on("resize", function (size) {
                ++g_resize_count;
                //document.title = g_resize_count.toString();
                var currentWidth=$("#instroduce").width();
                $("#descriptionImg").attr("src","http://resources.repo.so/org.thebigboss.protube/Description-" + currentWidth + ".jpg");
            });
        } catch (exp) {
            //   alert(exp.message);
            window.location="/Error404";
        }
    });

    /*页面卸载时*/
    $(window).unload(function () {
        try {
            $(window).jqElemResize("destroy");
        } catch (exp) {
            window.location="/Error404";
            //         alert(exp.message);
        }
    });
    //评论分页点击事件
    function commentAjax(page, container,pageType, packagename,effectId,curOrhis) {
        $(effectId).html("");
        $.ajax({
            type: "get",
            url: "/DebDetailPC/" + packagename + "?page=" + page + "&pageType=" + pageType,
            success: function (jsObj) {

                $(container).html(jsObj);
                $(effectId).fadeIn(function(){

                });
                if(curOrhis==1)
                {
                    $("#cur-loading-gif").addClass("hide");
                }
                else
                {
                    $("#his-loading-gif").addClass("hide");
                }
            }, error: function (jsOBj) {
                //  window.location = "/50PagePC.html";
                $(container).html("<p style='text-align:center;margin:100px 0'>评论列表显示错误,请刷新重试,或者联系我们...</p>");


            }
        });
        $(effectId).fadeIn();
    }
    /*禁止浏览器滚动*/
    var setPreventDefault = {
        oldScrollTop:0,/*记录滚动条位置*/
        docEle:document.documentElement,
        /*开始*/
        start:function(){
            this.oldScrollTop = this.docEle.scrollTop || document.body.scrollTop;

            this.docEle.className = 'setPreventDefault';
        },
        /*结束*/
        end:function(){
            this.docEle.className = '';
            window.scrollTo(0,this.oldScrollTop);
        }
    }
    //评测分页事件
    function reviewAjax(page,effectId)
    {

        $.ajax({
            type: "get",
            url: "/DebDetailPC/org.thebigboss.protube?page="+currentReviewPage+"&pageType=0",
            success: function (jsObj) {
                $("#pagerReview").html(jsObj);
                $(effectId).fadeIn(function(){

                    $("#review-loading-gif").addClass("hide");
                });

            }, error: function (jsOBj) {
                $(effectId).html("<p style='text-align:center;margin:100px 0'>评测列表显示错误,请刷新重试,或者联系我们...</p>").fadeIn();

                $("#review-loading-gif").addClass("hide");
                // window.location="/505PagerPC.html";
            }
        });

    }

    var picDisplay =
        Swipe($('#img-part')[0], {
            startSlide: 0,
            auto: 3000,
            continuous: false,
            callback: function (pos) {
                $("#pannel-part span").each(function () {
                    if ($(this).attr("tag") == pos) {
                        $(this).addClass("active").siblings().removeClass("active");
                    }
                })
            }
        });
    $(function () {
        var currentWidth=$("#instroduce").width();
        $("#descriptionImg").attr("src","http://resources.repo.so/org.thebigboss.protube/Description-" + currentWidth + ".jpg");

        $("#descriptionImg").load(function () {
            $("#picModal").fadeOut();
        })

        $("#right_button").bind("click",function(){
            $(".right-slider").toggleClass("width0")
        })

        //点击查看大图功能
        $("#img-part img").bind("click",function(){

            var imgPath= $(this).attr("src");
            $("#picDetail img").attr("src",imgPath);
            setPreventDefault.start();

        })
        //模态窗口消失的时候触发的事件
        $("#picDetail").bind('click', function (e) {

            setPreventDefault.end();
        })
        //图片预览左右
        $(".goLeft").click(function(){
            picDisplay.prev();
        })
        $(".goRight").click(function(){
            picDisplay.next();
        })
        //调整图片的高度 bug
        $("#img-part figure img").each(function(){
            var height= $(this).height();

            if(height<570)
            {
                if(height==0)
                {
                    setTimeout(function(){
                        if(height==0)
                        {
                            setTimeout(function(){
                                var  margintop = (570 - height) / 2;
                                $(this).css("margin-top",margintop);
                            },1000)
                        }
                        var  margintop = (570 - height) / 2;
                        $(this).css("margin-top",margintop);
                    },1000)
                }
                else{
                    var  margintop = (570 - height) / 2;
                }
                $(this).css("margin-top",margintop);
            }
        })

        var pointer=0;
        //用天花板函数来决定star
        var double_star=Math.ceil(pointer-1)/2;
        var only_star=Math.ceil(pointer)%2;

        for(var i=0;i<double_star;i++)
        {
            $($(".l-rate b span")[i]).addClass("icon-star-two").removeClass("icon-star-zero");
        }
        for(var j=double_star;j<double_star+only_star;j++)
        {
            $($(".l-rate b span")[i]).addClass("icon-star-one").removeClass("icon-star-zero");
        }

        //加减按钮的变化 以及collapse效果
        $(".small-am.btn").click(function(){
            if($(this).hasClass("icon-small-minus"))
            {
                $(this).removeClass("icon-small-minus").addClass("icon-small-add")
            }
            else{
                $(this).addClass("icon-small-minus").removeClass("icon-small-add")
            }
        })

        $(".big-am-btn").click(function(){
            if($(this).hasClass("icon-minus"))
            {
                $(this).removeClass("icon-minus").addClass("icon-add")
            }
            else{
                $(this).addClass("icon-minus").removeClass("icon-add")
            }
        })
        //上下箭头
        $(".bw-updown-collapse").click(function(){
            if($(this).hasClass("icon-white-drop-down"))
            {
                $(this).removeClass("icon-white-drop-down").addClass("icon-white-drop-top");

            }
            else{
                $(this).removeClass("icon-white-drop-top").addClass("icon-white-drop-down");
                //  $(".accordion-group .collapse").removeClass("in");
            }
        })

        $("#pannel-part span").bind("click", function () {
            if ($(this).attr("tag") != picDisplay.getPos()) {
                var times = parseInt($(this).attr("tag")) - parseInt(picDisplay.getPos());
                if (times > 0) {
                    for (var i = 0; i < times; i++) {
                        picDisplay.next();
                    }
                }
                else {
                    for (var i = 0; i > times; i--) {
                        picDisplay.prev();
                    }
                }
            }
        })
        $("#detail-Rpart2 .tab").click(function(){
            if($(this).hasClass("active"))
            {

            }
            else{
                $(this).addClass("active").siblings(".tab").removeClass("active")
            }
        })
        //评分的效果
        $(".rate>b>span").mouseover(function () {
            $(this).addClass("icon-star-two").removeClass("icon-star-zero").prevAll().addClass("icon-star-two").removeClass("icon-star-zero");
            $(this).nextAll().removeClass("icon-star-two").addClass("icon-star-zero");
            $("#thanks").html($('.rate>b .icon-star-two').length*2+" 分")
            
        })
        var lock=0;
        //刷新浏览此插件的人也浏览了
        $("#changeleftDebList").bind("click",function(){
            if(lock==0){

                lock=1;
                $("#glanceDebList").fadeOut(function(){
                    $("#glance-loading-gif").removeClass("hide")
                    $.ajax({
                        type:"Get",
                        url:"/Review/glanceDebList?ts="+Date.now(),

                        success:function(jsObj){
                            $("#glanceDebList").html(jsObj);
                            $("#glanceDebList").fadeIn(function(){
                                lock=0;

                            });
                            $("#glance-loading-gif").addClass("hide")
                        }
                            ,error:function(){
                                $("#glance-loading-gif").addClass("hide");
                                $("#glanceDebList").html("<p style='text-align:center;margin:100px 0'>暂无他人浏览项,请刷新重试...</p>").fadeIn();

                            }
                    })
                })

            }

        })

        //提交错误信息
        $(".right-slider .btn-submit").bind("click",function(){
            if($(".selectPannel :radio:checked").length==0)
            {
                alert("请选择错误的分类!");
            }
            else {

                var data = {
                    "type": $(".selectPannel :radio:checked").val(),
                    "note":$("#err-msg").val(),
                    "reviewdebversionid":3925,
                }

                $.ajax({
                    type:"Post",
                    url:"/CommitError",
                    data:data,
                    success:function(jsObj){
                        alert("您的提交已经成功")
                        $("textarea").val("");
                        $(".right-slider").addClass("width0");
                    }
                    ,error:function(){
                        alert("出现错误")
                    }
                },"JSON")
            }

        })
        //提交评论
        $("#btn-comment").bind("click", function () {
            if ($("#NickName").val() == "")
            {
                alert("您输入您的昵称");
                $("#NickName").focus();
            }
            else  if ($("#textarea").val() == "")
            {
                alert("您还未做评论哦");
                //   $("textarea").focus();
            }
            else {
                var data = {
                    "NickName": $("#NickName").val(),
                    "Graded": $(" #detail-Rpart2 .rate b .icon-star-two").length,//修改评分的提交规则
                    "CommentContent":$("textarea").val(),
                    "ReviewDebPrimaryID":2295,
                }
                $.ajax({
                    type:"Post",
                    url:"/CommitComment",
                    data:data,
                    success:function(jsObj){
                        if(jsObj.Status!=undefined)
                        {
                            alert(jsObj.Msg);
                        }
                        if(jsObj.Status!="err")
                        {
                            $("#curComments").html(jsObj);
                        }
                        $("textarea").val("");
                        $("#NickName").val("");
                        $("#thanks").html("(感谢你的评分)");
                        $("#thanks").show();
                    }
                },"JSON")
            }
        })


    })
</script>

    <div class="footer container-fluid">
        <div class="container">
            <div class="row" style="text-align: center">
                Copytight 2014 @REPO.SO  All Rights Reserved<br />
                粤ICP备14081675号
